<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Library App</title>
</head>

<body>
    <main class="homeContainer">
        <section class="heroCard">
            <h1>Step Into the Quiet Stacks</h1>
            <p>Welcome.<br>This digital library is currently optimized for desktop viewing only.  <br>
Smaller-screen chapters are still being written.</p>

            <% if (isLoggedIn) { %>
                <a class="btn" href="/books">Enter the Library</a>
                <form class="logoutForm" action="/logout" method="POST">
                    <button class="btn" type="submit">Log Out</button>
                </form>
            <% } else { %>
                <% if (loginRequired) { %>
                    <p class="loginMessage">Please log in to enter the library.</p>
                <% } %>

                <% if (loginError) { %>
                    <p class="loginMessage">That username or password was not recognized.</p>
                <% } %>

                <form class="loginForm" action="/login" method="POST">
                    <input type="text" name="username" placeholder="Username" required>
                    <input type="password" name="password" placeholder="Password" required>
                    <button class="btn" type="submit">Enter the Library</button>
                </form>
            <% } %>
        </section>
    </main>
</body>

</html>
