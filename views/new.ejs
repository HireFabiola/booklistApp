<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add a New Book</title>

    <style>
        body {
            margin: 0;
            min-height: 100vh;
            font-family: Georgia, serif;
            background-image: url("/image-1779301310374.png");
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .bookForm {
            position: absolute;
            top: 48%;
            left: 45.5%;
            transform: translate(-50%, -50%);
            width: clamp(240px, 28vw, 420px);
            height: clamp(360px, 42vw, 640px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #f7f2eb;
        }

        .bookForm input[type="text"] {
            width: 75%;
            background: transparent;
            border: none;
            border-bottom: 2px solid rgba(255, 255, 255, 0.65);
            color: #fff;
            text-align: center;
            font-family: Georgia, serif;
        }

        .bookForm input::placeholder {
            color: rgba(255, 255, 255, 0.65);
        }

        .titleField {
            font-size: clamp(1.6rem, 3vw, 3rem);
            font-weight: bold;
            letter-spacing: 0.08em;
            margin-bottom: 1.5rem;
        }

        .authorField {
            font-size: clamp(1rem, 1.5vw, 1.5rem);
            font-style: italic;
        }

        .bookOptions {
            position: absolute;
            bottom: 16%;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 1.5rem;
            align-items: center;
            justify-content: center;
            font-size: clamp(0.75rem, 1vw, 1rem);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #f7f2eb;
        }

        .bookOptions label {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .bookOptions input {
            width: 18px;
            height: 18px;
            accent-color: #d9b879;
        }

        .completedToggle label {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .completedToggle input {
            width: 18px;
            height: 18px;
            accent-color: #d9b879;
        }

        .submitBtn {
            position: absolute;
            bottom: 4%;
            left: 50%;
            transform: translateX(-50%);
            border: none;
            border-radius: 999px;
            padding: 0.9rem 1.5rem;
            background: #a36b2d;
            color: #fff;
            font-family: Georgia, serif;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
        }
    </style>
</head>

<body>
    <form action="/books" method="POST" class="bookForm">
        <input class="titleField" type="text" name="title" placeholder="Title?" required />

        <input class="authorField" type="text" name="author" placeholder="Author?" required />

        <div class="bookOptions">
            <label>
                <input type="checkbox" name="favorite" value="on" />
                Favorite?
            </label>

            <label>
                <input type="checkbox" name="completed" value="on" />
                Finished?
            </label>
        </div>

        <button class="submitBtn" type="submit">Add Book</button>
    </form>
</body>

</html>